{
  "name": "cloudflare-firewall-manager",
  "version": "1.0.0",
  "description": "Intelligent Cloudflare firewall rule manager with LLM support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:worker": "tsc --project tsconfig.worker.json",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "npx wrangler dev -c wrangler.full.toml",
    "deploy:worker": "npx wrangler deploy -c wrangler.full.toml",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.mjs",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.mjs tests/unit",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.mjs tests/integration",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.mjs --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.mjs --coverage",
    "test:verbose": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.mjs --verbose",
    "test:ci": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.mjs --coverage --watchAll=false --passWithNoTests",
    "generate-token": "tsx scripts/generate-token.ts",
    "categorize-domains": "tsx src/scripts/smart-domain-categorizer.ts",
    "gateway": "tsx src/cli/secure-natural-language-interface.ts",
    "gateway-basic": "tsx src/cli/natural-language-interface.ts",
    "security-scan": "tsx src/cli/security-scan-command.ts",
    "apply-rules": "tsx src/scripts/apply-project-dependencies.ts",
    "block-page": "tsx src/cli/block-page-command.ts",
    "mcp": "tsx src/cli/mcp-commands.ts",
    "mcp:test": "tsx src/scripts/test-mcp-integrations.ts",
    "mcp:status": "tsx src/cli/mcp-commands.ts status",
    "mcp:dashboard": "tsx src/cli/mcp-commands.ts dashboard",
    "mcp:workers": "tsx src/cli/mcp-commands.ts workers",
    "mcp:logs": "tsx src/cli/mcp-commands.ts logs",
    "mcp:security": "tsx src/cli/mcp-commands.ts security",
    "mcp:analytics": "tsx src/cli/mcp-commands.ts analytics",
    "mcp:auth": "tsx src/scripts/mcp-oauth-setup.ts",
    "mcp:auth:simple": "tsx src/scripts/mcp-simple-auth.ts",
    "mcp:auth:discover": "tsx src/scripts/mcp-auth-discovery.ts",
    "mcp:test-all": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx src/scripts/test-mcp-servers.ts",
    "prepare": "husky",
    "setup:ai-gateway": "tsx scripts/setup-ai-gateway.ts",
    "setup:vectorize": "npx wrangler vectorize create gateway-rules --dimensions 768 --metric cosine",
    "setup:d1": "npx wrangler d1 create firewall-db && npx wrangler d1 execute firewall-db --file=./schema.sql",
    "setup:r2": "npx wrangler r2 bucket create gateway-rule-backups",
    "setup:all": "npm run setup:ai-gateway && npm run setup:vectorize && npm run setup:d1 && npm run setup:r2",
    "migrate:ai": "tsx scripts/migrate-to-cloudflare-ai.ts",
    "tail:worker": "npx wrangler tail"
  },
  "keywords": [
    "cloudflare",
    "firewall",
    "api",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@modelcontextprotocol/sdk": "^1.17.3",
    "axios": "^1.7.2",
    "axios-retry": "^4.5.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "inquirer": "^9.2.23",
    "itty-router": "^4.0.26",
    "mcp-remote": "^0.1.18",
    "open": "^10.0.3",
    "ora": "^8.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-loader-spinner": "^6.1.6",
    "react-router-dom": "^6.21.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250820.0",
    "@jest/globals": "^30.0.5",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.9",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "husky": "^9.1.6",
    "jest": "^30.0.5",
    "jest-environment-node": "^30.0.5",
    "lint-staged": "^15.2.10",
    "nock": "^14.0.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3",
    "wrangler": "^4.31.0"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "npm run typecheck"
    ],
    "tests/**/*.{ts,js}": [
      "eslint --fix"
    ]
  }
}
