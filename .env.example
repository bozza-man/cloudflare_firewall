# Cloudflare API credentials
# Option 1: API Token (recommended - will be generated automatically if you have global key)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Option 2: Global API Key (used to generate API token)
CLOUDFLARE_GLOBAL_KEY=your_global_api_key
CLOUDFLARE_EMAIL=your_cloudflare_email

# Required: Your Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID=your_account_id

# Anthropic API key for AI features
ANTHROPIC_API_KEY=your_anthropic_api_key

# OSINT (Open Source Intelligence) Configuration
# Enable free OSINT services (no API keys required)
OSINT_ENABLE_FREE_SERVICES=true

# Premium OSINT API keys (optional)
# WHOISXML_API_KEY=your_whoisxml_api_key
# SECURITYTRAILS_API_KEY=your_securitytrails_api_key
# CLEARBIT_API_KEY=your_clearbit_api_key
# HUNTER_API_KEY=your_hunter_api_key

# OSINT Performance Settings
OSINT_MAX_CONCURRENT=3
OSINT_RATE_LIMIT_MS=1000
OSINT_TIMEOUT_MS=10000
OSINT_DNS_TIMEOUT_MS=5000

# OSINT Feature Toggles
OSINT_ENABLE_WHOIS=true
OSINT_ENABLE_DNS=true
OSINT_ENABLE_GEO=true
OSINT_ENABLE_CT=true
OSINT_ENABLE_SUBDOMAINS=true
