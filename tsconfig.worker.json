{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "WebWorker"],
    "types": [],
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "./dist/worker",
    "rootDir": "./src/worker",
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/worker/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
